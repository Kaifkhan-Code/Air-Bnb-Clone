<% layout('layouts/boilerplate') -%>

<body>
  <div class="container mt-4">
    <div class="row">
      <div class="col-8 offset-2">
        <!-- Title -->
        <h3 class="mb-4 text-center" style="text-decoration: underline;">
          <b><%= listing.title %></b>
        </h3>

        <!-- Listing Card -->
        <div class="card mx-auto shadow" style="width: 30rem;">
          <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="<%= listing.title %>">

          <div class="card-body text-center">
            <p><i>Owned By: <%= listing.owner ? listing.owner.username : "Unknown" %></i></p>

            <!--  Base Price Section -->
            <div>
              <p class="price-night mb-1">
                <strong>Price:</strong> ₹<%= listing.price.toLocaleString("en-IN") %> / night
              </p>

              <% 
                const serviceFee = listing.price * 0.10;
                const taxes = listing.price * 0.12;
                const totalPay = listing.price + serviceFee + taxes;
              %>

              <!-- 💵 Total After Taxes (Hidden by Default) -->
              <p class="price-total text-muted d-none">
                <strong>Total After Taxes:</strong> ₹<%= totalPay.toFixed(0).toLocaleString("en-IN") %>
              </p>
            </div>

            <p class="mb-1"><strong>Location:</strong> <%= listing.location %>, <%= listing.country %></p>
          </div>

          <!-- Owner Controls -->
          <% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
            <div class="card-body text-center">
              <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark me-2">Edit Listing</a>

              <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" style="display:inline;">
                <button type="submit" class="btn btn-danger"
                  onclick="return confirm('Are you sure you want to delete this listing?');">
                  Delete Listing
                </button>
              </form>
            </div>
          <% } %>

          <div class="text-center mb-3">
            <a href="/listings" class="btn btn-secondary">Back to all listings</a>
          </div>
        </div>

        <!--  Toggle Switch for Taxes -->
        <div class="d-flex justify-content-center align-items-center mt-4">
          <label class="form-check-label me-2 fw-semibold" for="toggleTaxes">Show total after taxes</label>
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="toggleTaxes">
          </div>
        </div>

        <hr>

        <!-- ✍️ Review Form -->
        <% if(currUser) { %>
          <div class="col-10 offset-1 mt-4">
            <h4>Leave a Review</h4>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
              <div class="mb-3">
                <label for="rating" class="form-label">Rating</label>
                <select class="form-select" id="rating" name="review[rating]" required>
                  <option value="1">1 - Poor</option>
                  <option value="2">2 - Fair</option>
                  <option value="3">3 - Good</option>
                  <option value="4">4 - Very Good</option>
                  <option value="5">5 - Excellent</option>
                </select>
              </div>

              <div class="mb-3">
                <label for="review" class="form-label">Your Review</label>
                <textarea class="form-control" id="review" name="review[comment]" rows="3" required></textarea>
              </div>

              <button type="submit" class="btn btn-primary">Submit Review</button>
            </form>
          </div>
          <hr>
        <% } %>

        <!-- 📝 Reviews Section -->
        <h4 class="mb-3">Reviews</h4>
        <div class="row g-4">
          <% if (!listing.reviews || listing.reviews.length === 0) { %>
            <p>No reviews yet. Be the first to review!</p>
          <% } else { %>
            <% listing.reviews.forEach(review => { %>
              <div class="col-md-6">
                <div class="card border border-2 border-primary rounded-3 shadow-sm h-100">
                  <div class="card-body">
                    <p class="card-text"><b><%= review.author.username %></b></p>
                    <p class="card-text">⭐ Rating: <%= review.rating %> / 5</p>
                    <p class="card-text"><%= review.comment %></p>
                    <p class="card-text">
                      <small class="text-muted">
                        Reviewed on <%= review.createdAt ? review.createdAt.toDateString() : "Unknown date" %>
                      </small>
                    </p>
                  </div>

                  <% if(currUser && review.author && currUser._id.equals(review.author._id)) { %>
                    <div class="card-footer bg-transparent border-top-0">
                      <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-sm btn-dark">Delete</button>
                      </form>
                    </div>
                  <% } %>
                </div>
              </div>
            <% }) %>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <!-- Tax Toggle Script -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const toggle = document.getElementById("toggleTaxes");
      const priceNight = document.querySelector(".price-night");
      const priceTotal = document.querySelector(".price-total");

      toggle.addEventListener("change", () => {
        if (toggle.checked) {
          priceNight.classList.add("d-none");
          priceTotal.classList.remove("d-none");
        } else {
          priceNight.classList.remove("d-none");
          priceTotal.classList.add("d-none");
        }
      });
    });
  </script>
</body>
